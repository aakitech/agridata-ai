# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/agridata"

# Supabase (Client)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Supabase (Server)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Twilio
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# Weather Enrichment
WEATHER_PROVIDER="open-meteo"
WEATHER_ENRICHMENT_CRON_SECRET="replace-with-a-long-random-secret"
WEATHER_ENRICHMENT_BATCH_SIZE="25"
WEATHER_ENRICHMENT_MAX_RETRIES="3"
WEATHER_ENRICHMENT_BASE_BACKOFF_MINUTES="5"
WEATHER_DEFAULT_TIMEZONE="Africa/Harare"
